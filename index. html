<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>🐇 ZeroOne Wonderland · عالم أليس الرقمي</title>
    <style>
        body { margin: 0; overflow: hidden; font-family: 'Cairo', sans-serif; background: #000; }
        #welcome-message {
            position: absolute; top: 20px; left: 20px; color: #ffaa00;
            background: rgba(10,20,30,0.7); padding: 8px 20px; border-radius: 40px;
            backdrop-filter: blur(5px); border: 1px solid #00ffcc; z-index: 100;
            pointer-events: none; font-size: 1rem;
        }
        #controls-hint {
            position: absolute; bottom: 20px; left: 50%; transform: translateX(-50%);
            color: #00ffcc; background: rgba(0,0,0,0.5); padding: 8px 20px;
            border-radius: 40px; backdrop-filter: blur(5px); z-index: 100;
            pointer-events: none; font-size: 0.9rem;
        }
        /* نوافذ CSS2D ستظهر هنا */
        .window-container { pointer-events: none; }
        .window-container > div { pointer-events: auto; }
    </style>
    <!-- الخطوط والمكتبات -->
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;700;900&display=swap" rel="stylesheet">
    <script type="importmap">
        {
            "imports": {
                "three": "https://unpkg.com/three@0.128.0/build/three.module.js",
                "three/addons/": "https://unpkg.com/three@0.128.0/examples/jsm/"
            }
        }
    </script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/crypto-js/4.1.1/crypto-js.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/FileSaver.js/2.0.5/FileSaver.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@xenova/transformers@2.17.2/dist/transformers.min.js"></script>
</head>
<body>
    <div id="welcome-message">🐇 مرحباً بك في مملكتك · ZeroOne Wonderland</div>
    <div id="controls-hint">👆 المس أي بوابة لفتح العالم · اسحب لاستكشاف المملكة</div>

    <script type="module">
        // ==================== استيراد المكتبات ====================
        import * as THREE from 'three';
        import { OrbitControls } from 'three/addons/controls/OrbitControls.js';
        import { CSS2DRenderer, CSS2DObject } from 'three/addons/renderers/CSS2DRenderer.js';
        import { Reflector } from 'three/addons/objects/Reflector.js';

        // ==================== كائن المملكة العالمي ====================
        window.Wonderland = {
            scene: null, camera: null, renderer: null, cssRenderer: null, controls: null,
            showMessage: (msg) => { console.log(msg); },
            openDB: null, // سنضعه لاحقاً
            activeWindows: []
        };

        // ==================== التهيئة العامة للمشهد ====================
        const scene = new THREE.Scene();
        scene.background = new THREE.Color(0x050520);
        scene.fog = new THREE.FogExp2(0x050520, 0.003);
        window.Wonderland.scene = scene;

        const camera = new THREE.PerspectiveCamera(55, window.innerWidth / window.innerHeight, 0.1, 1000);
        camera.position.set(0, 6, 14);
        camera.lookAt(0, 2, 0);
        window.Wonderland.camera = camera;

        const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: false });
        renderer.setSize(window.innerWidth, window.innerHeight);
        renderer.shadowMap.enabled = true;
        renderer.shadowMap.type = THREE.PCFSoftShadowMap;
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
        document.body.appendChild(renderer.domElement);
        window.Wonderland.renderer = renderer;

        const cssRenderer = new CSS2DRenderer();
        cssRenderer.setSize(window.innerWidth, window.innerHeight);
        cssRenderer.domElement.style.position = 'absolute';
        cssRenderer.domElement.style.top = '0';
        cssRenderer.domElement.style.left = '0';
        cssRenderer.domElement.classList.add('window-container');
        document.body.appendChild(cssRenderer.domElement);
        window.Wonderland.cssRenderer = cssRenderer;

        const controls = new OrbitControls(camera, renderer.domElement);
        controls.enableDamping = true;
        controls.dampingFactor = 0.05;
        controls.autoRotate = true;
        controls.autoRotateSpeed = 0.5;
        controls.enableZoom = true;
        controls.enablePan = true;
        controls.target.set(0, 2.5, 0);
        controls.maxPolarAngle = Math.PI / 2.2;
        window.Wonderland.controls = controls;

        // ==================== الإضاءة ====================
        scene.add(new THREE.AmbientLight(0x404066));
        const mainLight = new THREE.DirectionalLight(0xffeedd, 1.2);
        mainLight.position.set(5, 12, 8);
        mainLight.castShadow = true;
        mainLight.receiveShadow = true;
        mainLight.shadow.mapSize.width = 2048;
        mainLight.shadow.mapSize.height = 2048;
        scene.add(mainLight);
        
        const fillLight = new THREE.PointLight(0x4466ff, 0.6);
        fillLight.position.set(-4, 3, 6);
        scene.add(fillLight);
        
        const portalLight = new THREE.PointLight(0xffaa00, 1.5);
        portalLight.position.set(0, 3, 0);
        scene.add(portalLight);

        // ==================== أرضية عاكسة (عالم الأحلام) ====================
        const reflector = new Reflector(new THREE.PlaneGeometry(30, 30), {
            clipBias: 0.003, textureWidth: 2048, textureHeight: 2048, color: 0x1a1a3a
        });
        reflector.rotateX(-Math.PI / 2);
        reflector.position.y = -0.01;
        reflector.receiveShadow = true;
        scene.add(reflector);

        // ==================== عناصر المملكة ====================

        // --- 1. الجزيرة المركزية (مكان التجمع) ---
        const islandMat = new THREE.MeshStandardMaterial({ color: 0x2a2a5a, roughness: 0.7, metalness: 0.1 });
        const island = new THREE.Mesh(new THREE.CylinderGeometry(4.5, 5, 0.5, 8), islandMat);
        island.position.y = 0.25;
        island.receiveShadow = true;
        island.castShadow = true;
        scene.add(island);
        
        const centerPillar = new THREE.Mesh(new THREE.CylinderGeometry(0.8, 1, 1.2, 6), new THREE.MeshStandardMaterial({ color: 0xffaa00, roughness: 0.3, metalness: 0.6 }));
        centerPillar.position.y = 0.85;
        centerPillar.receiveShadow = true;
        centerPillar.castShadow = true;
        scene.add(centerPillar);
        
        // ساعة الأرنب (رمز أليس)
        const clockGroup = new THREE.Group();
        const clockFace = new THREE.Mesh(new THREE.CylinderGeometry(1.2, 1.2, 0.1, 12), new THREE.MeshStandardMaterial({ color: 0xffffff, emissive: new THREE.Color(0x664422) }));
        clockFace.rotation.y = Math.PI / 2;
        clockFace.position.y = 1.5;
        clockFace.castShadow = true;
        clockFace.receiveShadow = true;
        clockGroup.add(clockFace);
        
        const handMat = new THREE.MeshStandardMaterial({ color: 0x000000 });
        const hourHand = new THREE.Mesh(new THREE.BoxGeometry(0.6, 0.05, 0.05), handMat);
        hourHand.position.set(0.3, 1.5, 0);
        hourHand.castShadow = true;
        clockGroup.add(hourHand);
        const minuteHand = new THREE.Mesh(new THREE.BoxGeometry(0.8, 0.05, 0.05), handMat);
        minuteHand.position.set(0.4, 1.5, 0);
        minuteHand.rotation.z = 0.5;
        minuteHand.castShadow = true;
        clockGroup.add(minuteHand);
        
        clockGroup.position.y = 0.2;
        clockGroup.position.x = 0.5;
        clockGroup.position.z = 0.5;
        scene.add(clockGroup);

        // --- 2. البوابات (الكواكب الوظيفية) ---
        const portals = [
            { name: '🔐 الخزنة', color: 0xffaa00, pos: [-3, 2.5, 2], action: 'vault' },
            { name: '🤖 الذكاء', color: 0x00ffcc, pos: [3, 2.5, 2], action: 'ai' },
            { name: '⚙️ الإعدادات', color: 0x4466ff, pos: [-3, 2.5, -2], action: 'system' },
            { name: '✨ الإبداع', color: 0xff55ff, pos: [3, 2.5, -2], action: 'creative' }
        ];

        const portalMeshes = [];
        portals.forEach((p, i) => {
            const sphere = new THREE.Mesh(new THREE.SphereGeometry(0.9, 32, 16), 
                new THREE.MeshStandardMaterial({ color: p.color, roughness: 0.2, metalness: 0.1, emissive: new THREE.Color(p.color).multiplyScalar(0.3) }));
            sphere.position.set(p.pos[0], p.pos[1], p.pos[2]);
            sphere.castShadow = true;
            sphere.receiveShadow = true;
            sphere.userData = { action: p.action, name: p.name };
            scene.add(sphere);
            portalMeshes.push(sphere);
            
            // حلقة دائرية حول الكوكب
            const ring = new THREE.Mesh(new THREE.TorusGeometry(1.2, 0.03, 16, 64), new THREE.MeshStandardMaterial({ color: p.color, emissive: new THREE.Color(p.color).multiplyScalar(0.2) }));
            ring.rotation.x = Math.PI / 2;
            ring.rotation.y = i * 1.5;
            ring.position.copy(sphere.position);
            scene.add(ring);
            
            // تسمية CSS2D
            const div = document.createElement('div');
            div.textContent = p.name;
            div.style.color = '#fff';
            div.style.fontSize = '20px';
            div.style.fontWeight = 'bold';
            div.style.fontFamily = 'Cairo';
            div.style.textShadow = `0 0 20px ${new THREE.Color(p.color).getStyle()}`;
            div.style.pointerEvents = 'none';
            const label = new CSS2DObject(div);
            label.position.set(p.pos[0], p.pos[1] + 1.4, p.pos[2]);
            scene.add(label);
        });

        // --- 3. أشجار وزهور سحرية (لإضفاء الحياة) ---
        function createTree(x, z) {
            const group = new THREE.Group();
            const trunk = new THREE.Mesh(new THREE.CylinderGeometry(0.2, 0.3, 1.5), new THREE.MeshStandardMaterial({ color: 0x8B5E3C }));
            trunk.position.y = 0.75;
            trunk.castShadow = true;
            trunk.receiveShadow = true;
            group.add(trunk);
            
            const leavesMat = new THREE.MeshStandardMaterial({ color: 0x88ff88, emissive: new THREE.Color(0x224422) });
            for (let i = 0; i < 3; i++) {
                const leaf = new THREE.Mesh(new THREE.SphereGeometry(0.5, 6), leavesMat);
                leaf.position.y = 1.3 + i*0.4;
                leaf.position.x = Math.sin(i)*0.3;
                leaf.position.z = Math.cos(i)*0.3;
                leaf.castShadow = true;
                leaf.receiveShadow = true;
                group.add(leaf);
            }
            group.position.set(x, 0, z);
            return group;
        }

        scene.add(createTree(-5, -4));
        scene.add(createTree(5, -4));
        scene.add(createTree(-5, 5));
        scene.add(createTree(6, 3));

        // جسيمات عائمة (غبار النجوم)
        const starsParticles = new THREE.BufferGeometry();
        const starsCount = 800;
        const posArray = new Float32Array(starsCount * 3);
        for (let i = 0; i < starsCount * 3; i+=3) {
            posArray[i] = (Math.random() - 0.5) * 40;
            posArray[i+1] = Math.random() * 8;
            posArray[i+2] = (Math.random() - 0.5) * 40;
        }
        starsParticles.setAttribute('position', new THREE.BufferAttribute(posArray, 3));
        const particleMat = new THREE.PointsMaterial({ color: 0xaaccff, size: 0.05, transparent: true });
        const particles = new THREE.Points(starsParticles, particleMat);
        scene.add(particles);

        // ==================== نظام النوافذ (مبني على ZeroOne OS) ====================
        // سنقوم بتحميل وظائف الخزنة والذكاء الاصطناعي هنا
        async function openDB() {
            return new Promise((res, rej) => {
                const req = indexedDB.open('ZeroOneVault', 1);
                req.onupgradeneeded = (e) => e.target.result.createObjectStore('files');
                req.onsuccess = (e) => res(e.target.result);
                req.onerror = rej;
            });
        }
        window.Wonderland.openDB = openDB;

        // نافذة VAULT EXPLORER
        function openVaultExplorer() {
            // ... (نسخة مبسطة من نافذة الخزنة)
            console.log('🔓 فتح الخزنة');
        }

        // نافذة AI TERMINAL
        async function openAITerminal() {
            // ... (نسخة مبسطة من نافذة الذكاء)
            console.log('🤖 فتح محطة الذكاء');
        }

        // ==================== التفاعل باللمس (Raycaster) ====================
        const raycaster = new THREE.Raycaster();
        const mouse = new THREE.Vector2();
        
        renderer.domElement.addEventListener('click', (event) => {
            // حساب موقع اللمس
            const rect = renderer.domElement.getBoundingClientRect();
            mouse.x = ((event.clientX - rect.left) / rect.width) * 2 - 1;
            mouse.y = -((event.clientY - rect.top) / rect.height) * 2 + 1;
            
            raycaster.setFromCamera(mouse, camera);
            const intersects = raycaster.intersectObjects(portalMeshes);
            
            if (intersects.length > 0) {
                const portal = intersects[0].object;
                const action = portal.userData.action;
                // فتح العالم المناسب
                if (action === 'vault') openVaultExplorer();
                else if (action === 'ai') openAITerminal();
                else if (action === 'system') console.log('⚙️ فتح الإعدادات');
                else if (action === 'creative') console.log('✨ فتح عالم الإبداع');
                
                // تأثير بصري: نبض الكوكب
                portal.scale.set(1.2, 1.2, 1.2);
                setTimeout(() => portal.scale.set(1, 1, 1), 200);
            }
        });

        // دعم اللمس
        renderer.domElement.addEventListener('touchstart', (e) => {
            e.preventDefault();
            const touch = e.touches[0];
            const fakeEvent = { clientX: touch.clientX, clientY: touch.clientY };
            renderer.domElement.dispatchEvent(new MouseEvent('click', fakeEvent));
        }, { passive: false });

        // ==================== حلقة الرسم ====================
        function animate() {
            requestAnimationFrame(animate);
            
            // دوران البوابات ببطء
            portalMeshes.forEach((p, i) => {
                p.rotation.y += 0.005;
                p.rotation.x = Math.sin(performance.now() * 0.001 + i) * 0.1;
            });
            
            // دوران عقارب الساعة
            if (clockGroup) {
                clockGroup.children[1].rotation.z += 0.005;
                clockGroup.children[2].rotation.z += 0.02;
            }
            
            controls.update();
            renderer.render(scene, camera);
            cssRenderer.render(scene, camera);
        }
        animate();

        window.addEventListener('resize', () => {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
            cssRenderer.setSize(window.innerWidth, window.innerHeight);
        });

        console.log('🐇 ZeroOne Wonderland · مملكتك الرقمية جاهزة');
    </script>
</body>
</html>
